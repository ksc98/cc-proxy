---
import "@/styles/global.css";
import { Sidebar } from "@/components/Sidebar";
import LiveHeaderStats from "@/components/LiveHeaderStats";
import type { SessionSummary } from "@/lib/sessions";

interface Props {
  title?: string;
  headerStats?: {
    spendUsd: number;
    turns: number;
    sessions: number;
    activeSession?: string | null;
    /** Trailing $/min burn rate. Hidden when null/0. */
    burnUsdPerMin?: number | null;
    /** Fraction of recent turns that failed (0..1). Hidden when null/0. */
    errorRate?: number | null;
    /** Most-recent rate-limit snapshot from Anthropic's response headers. */
    rateLimit?: {
      tokRemaining: number;
      tokLimit: number;
    } | null;
  };
  /** Full session list for the sidebar nav. */
  sessions?: SessionSummary[];
  /** Highlighted session in the sidebar (on drilldown pages). */
  currentSessionId?: string | null;
}
const {
  title = "Burnage",
  headerStats,
  sessions = [],
  currentSessionId = null,
} = Astro.props;

// The header's live buses (global stats + windowed rows + all sessions)
// only make sense on the overview page — session-detail pages pass
// session-scoped headerStats values that we shouldn't clobber with global
// totals after hydration.
const headerLive = Astro.url.pathname === "/";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{title}</title>
    <script is:inline>
      document.documentElement.setAttribute("data-session-filter", "active");
    </script>
  </head>
  <body class="flex min-h-screen">
    <Sidebar
      client:load
      sessions={sessions}
      currentSessionId={currentSessionId}
    />
    <div class="flex-1 flex flex-col min-w-0">
    <header class="sticky top-0 z-20 backdrop-blur-xl bg-[var(--color-background)]/80 border-b border-[var(--color-border)]">
      <div class="px-4 sm:px-6 h-14 flex items-center justify-between gap-3 sm:gap-6">
        <div class="flex items-center gap-3 sm:gap-6 min-w-0">
          <button
            type="button"
            id="cm-mobile-sidebar-trigger"
            class="md:hidden inline-flex items-center justify-center h-8 w-8 -ml-1 rounded-md text-[var(--color-subtle-foreground)] hover:text-[var(--color-foreground)] hover:bg-[var(--color-card)]"
            aria-label="Open navigation"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" y1="6" x2="20" y2="6"/><line x1="4" y1="12" x2="20" y2="12"/><line x1="4" y1="18" x2="20" y2="18"/></svg>
          </button>
          {
            headerStats && (
              <LiveHeaderStats
                client:load
                live={headerLive}
                initialStats={{
                  spendUsd: headerStats.spendUsd,
                  turns: headerStats.turns,
                  sessions: headerStats.sessions,
                  activeSession: headerStats.activeSession ?? null,
                  burnUsdPerMin: headerStats.burnUsdPerMin ?? null,
                  errorRate: headerStats.errorRate ?? null,
                  rateLimit: headerStats.rateLimit ?? null,
                }}
              />
            )
          }
        </div>
      </div>
      <slot name="breadcrumb" />
    </header>
    <main class="px-6 py-8 w-full max-w-7xl mx-auto">
      <slot />
    </main>
    </div>

    <script>
      // --- Mobile sidebar trigger: dispatch event consumed by Sidebar.tsx ---
      const trigger = document.getElementById("cm-mobile-sidebar-trigger");
      trigger?.addEventListener("click", () => {
        window.dispatchEvent(new CustomEvent("cm:open-mobile-sidebar"));
      });

      // --- 1-second ticker for every [data-ts] element. ---
      // Updates inner text to the current "Xs / Xm / Xh / Xd" ago value.
      function fmtAgo(ms: number): string {
        const diff = Date.now() - ms;
        const s = Math.max(0, Math.floor(diff / 1000));
        if (s < 60) return `${s}s`;
        const m = Math.floor(s / 60);
        const rs = s % 60;
        if (m < 60) return rs > 0 ? `${m}m${rs}s` : `${m}m`;
        const h = Math.floor(m / 60);
        const rm = m % 60;
        if (h < 24) return rm > 0 ? `${h}h${rm}m` : `${h}h`;
        const days = Math.floor(h / 24);
        const rh = h % 24;
        return rh > 0 ? `${days}d${rh}h` : `${days}d`;
      }
      function refreshAges() {
        document.querySelectorAll<HTMLElement>("[data-ts]").forEach((el) => {
          const ts = Number(el.dataset.ts);
          if (!Number.isFinite(ts)) return;
          const suffix = el.dataset.tsSuffix ?? "";
          el.textContent = fmtAgo(ts) + suffix;
        });
      }
      setInterval(refreshAges, 1000);
    </script>
  </body>
</html>
