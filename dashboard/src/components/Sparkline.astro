---
// Pure-SVG sparkline, server-rendered, no JS.
// Modes:
//   "line"  — polyline, good for rolling averages / rates
//   "bars"  — vertical bars, good for per-turn distribution
interface Props {
  values: number[];
  mode?: "line" | "bars";
  width?: number;
  height?: number;
  color?: string; // any CSS color or var(--color-*)
  fillOpacity?: number;
  strokeWidth?: number;
}

const {
  values,
  mode = "line",
  width = 120,
  height = 32,
  color = "var(--color-volume)",
  fillOpacity = 0.18,
  strokeWidth = 1.5,
} = Astro.props;

const safeVals = values.length > 0 ? values : [0];
const min = Math.min(...safeVals);
const max = Math.max(...safeVals);
const range = max - min || 1;
const n = safeVals.length;

function x(i: number) {
  if (n === 1) return width / 2;
  return (i / (n - 1)) * width;
}
function y(v: number) {
  const t = (v - min) / range;
  return height - t * (height - 2) - 1; // 1px padding top/bottom
}

let pathD = "";
let areaD = "";
if (mode === "line") {
  pathD = safeVals.map((v, i) => `${i === 0 ? "M" : "L"}${x(i).toFixed(2)} ${y(v).toFixed(2)}`).join(" ");
  areaD =
    `M0 ${height} ` +
    safeVals.map((v, i) => `L${x(i).toFixed(2)} ${y(v).toFixed(2)}`).join(" ") +
    ` L${width} ${height} Z`;
}
---

<svg
  width={width}
  height={height}
  viewBox={`0 0 ${width} ${height}`}
  preserveAspectRatio="none"
  class="block"
  style={`max-width:${width}px;width:100%;height:${height}px`}
  aria-hidden="true"
>
  {
    mode === "line" && (
      <>
        <path d={areaD} fill={color} fill-opacity={fillOpacity} />
        <path
          d={pathD}
          fill="none"
          stroke={color}
          stroke-width={strokeWidth}
          stroke-linecap="round"
          stroke-linejoin="round"
        />
      </>
    )
  }
  {
    mode === "bars" &&
      safeVals.map((v, i) => {
        // Aim for a small, fixed-looking gap (~1 viewBox unit) regardless of
        // count — 70% slots looked airy when stretched to card width.
        const slot = width / n;
        const gap = Math.min(1, slot * 0.15);
        const barW = Math.max(0.5, slot - gap);
        const barX = i * slot + gap / 2;
        const h = ((v - min) / range) * (height - 2);
        const barY = height - h - 1;
        return (
          <rect
            x={barX.toFixed(2)}
            y={barY.toFixed(2)}
            width={barW.toFixed(2)}
            height={Math.max(1, h).toFixed(2)}
            fill={color}
            rx="0.5"
          />
        );
      })
  }
</svg>
